#!/usr/bin/env sh
set -e

GRADLE_VERSION=8.2.1
DIST_URL="https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"
WRAPPER_DIR="$(cd "$(dirname "$0")" && pwd)/.gradle-wrapper"
GRADLE_DIR="$WRAPPER_DIR/gradle-${GRADLE_VERSION}"
GRADLE_BIN="$GRADLE_DIR/bin/gradle"

if [ ! -x "$GRADLE_BIN" ]; then
  mkdir -p "$WRAPPER_DIR"
  echo "Downloading Gradle ${GRADLE_VERSION}..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DIST_URL" -o "$WRAPPER_DIR/gradle-${GRADLE_VERSION}-bin.zip"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$DIST_URL" -O "$WRAPPER_DIR/gradle-${GRADLE_VERSION}-bin.zip"
  else
    echo "curl or wget is required to download Gradle." >&2
    exit 1
  fi
  unzip -q -o "$WRAPPER_DIR/gradle-${GRADLE_VERSION}-bin.zip" -d "$WRAPPER_DIR"
fi

exec "$GRADLE_BIN" "$@"
