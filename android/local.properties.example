# Copy to local.properties and adjust to your machine path.
# Example:
# sdk.dir=C:\\Users\\<you>\\AppData\\Local\\Android\\Sdk

sdk.dir=

# Volcengine ASR SDK (com.bytedance.speechengine:speechengine_asr_tob)
# Required:
# volcengineAppId=your_app_id
# volcengineToken=your_access_token
# volcengineAsrCluster=your_asr_cluster
#   (If using /api/v3/sauc/bigmodel route, you can also provide volcengineResourceId instead of cluster)
# Alias keys also supported:
# volcengineCluster / VOLCENGINE_ASR_CLUSTER / VOLCENGINE_CLUSTER
#
# Optional:
# volcengineAsrAddress=wss://openspeech.bytedance.com
# volcengineAsrUri=/api/v2/asr
# volcengineUid=versementor-android
# volcengineResourceId=
