# Copy to local.properties and adjust to your machine path.
# Example:
# sdk.dir=C:\\Users\\<you>\\AppData\\Local\\Android\\Sdk

sdk.dir=

# Volcengine ASR (streaming)
# Required:
# volcAsrAppId=your_app_id
# volcAsrToken=your_access_token
# volcAsrCluster=your_asr_cluster
#
# Optional:
# volcAsrAddress=wss://openspeech.bytedance.com
# volcAsrUri=/api/v2/asr
# volcAsrUid=versementor-android
# volcAsrResourceId=
#
# Volcengine TTS (bigmodel route)
# Optional but recommended when pairing with `volc_asr`:
# volcTtsAppId=your_app_id
# volcTtsToken=your_access_token
# volcTtsCluster=your_tts_cluster
# volcTtsAddress=wss://openspeech.bytedance.com
# volcTtsUri=/api/v3/tts/bigmodel
# volcTtsUid=versementor-android
# volcTtsResourceId=
#
# Legacy VOLCENGINE_* keys remain backward-compatible and will emit compat warnings at runtime.
